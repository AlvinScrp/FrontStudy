/**index.wxss**/
@import "../../common/common.wxss";

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-size: 25px;
  text-align: center;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

input {
  border: 1px solid #eee;
  padding: 5px;
  margin: 5px;
  background-color: #f5f5f5;
  border-radius: 3px;
}