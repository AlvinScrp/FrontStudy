@import '../../template/tab-bottom/index.wxss';

.first {
  background-color: blanchedalmond;
  color: red;
  font-size: 40rpx;
  padding: 24rpx;
}

.c-c {
  width: 100%;
}

.banners {
  width: 100%;
  height: 750rpx;

}

.banner {}

.banner-image {
  width: 100%;
