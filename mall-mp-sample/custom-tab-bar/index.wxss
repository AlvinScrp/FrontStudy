/* custom-tab-bar/index.wxss */
.tabs {
  display: flex;
  height: 130rpx;
  width: 100%;
  flex-direction: row;
  flex-wrap: nowrap;
  background-color: white;
  border-top: solid;
  border-color: #eee;
  border-width: 1rpx;

}

.tab {
  padding-top: 12rpx;
  height: 100%;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  align-items: center;

}

.tab-image {
  width: 40rpx;
  height: 40rpx;
}

.tab-text {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: black;
}

.tab-text-active {
  color: palevioletred;
}